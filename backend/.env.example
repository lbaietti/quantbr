# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production          # development | production
APP_DEBUG=false
APP_VERSION=1.0.0

# ── API Security (ISO 27001 A.9, A.10) ───────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://quantbr:password@127.0.0.1:5432/quantbr
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── ZMQ feed (from C++ process) ───────────────────────────────────────────────
ZMQ_FEED_ENDPOINT=tcp://localhost:5555

# ── CORS (ISO 27001 A.14 — restrict origins in production) ────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── Rate limiting (ISO 27001 A.14) ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── AI Agents — Anthropic Claude API ─────────────────────────────────────────
# Required to use the AI agents sidebar (Quant Dev / Researcher / Operator)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AGENT_MESSAGES_PER_HOUR=20

# ── Audit log (ISO 27001 A.12) ────────────────────────────────────────────────
AUDIT_LOG_LEVEL=INFO
